# =============================================================================
# Go
# =============================================================================
*.exe
*.dll
*.so
*.dylib
*.test
*.out
/bin/
/dist/
/deploy/bin/

# =============================================================================
# 本地配置 / 密钥(绝对不能进仓库)
# =============================================================================
/configs/config.yaml
/configs/*.local.yaml
/deploy/.env
.env
.env.local

# =============================================================================
# IDE
# =============================================================================
.idea/
.vscode/
*.swp
*.swo

# =============================================================================
# 日志 & 数据
# =============================================================================
/logs/
/deploy/logs/
*.log
/data/
/uploads/
/storage/

# =============================================================================
# 前端
# =============================================================================
/web/node_modules/
/web/dist/
/web/.cache/
/web/.vite/

# =============================================================================
# Python(仅 legacy 参考)
# =============================================================================
__pycache__/
*.pyc
*.pyo
.venv/
venv/

# =============================================================================
# 打包产物 / 临时目录(不要提交到开源仓库)
# =============================================================================
*.tgz
*.tar.gz
/_tmp/
/tmp/

# 历史部署产物(运维自己 build 即可,不要带进仓库)
/deploy/bin/
/deploy/logs/
/deploy/updates/
/deploy/web/

# =============================================================================
# 杂项
# =============================================================================
.DS_Store
Thumbs.db
*.bak
*.tmp
*_backup_*

# =============================================================================
# 根目录随手放的哈希命名图片 / HAR(README 正式图放 docs/screenshots/)
# =============================================================================
/[0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f]*.png
/[0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f]*.jpg
/[0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f]*.har
!/docs/**
